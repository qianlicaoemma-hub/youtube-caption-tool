# 火山引擎/豆包 大模型录音文件识别（ASR）必填四件套：
#
# 1) 语音控制台 → 应用管理 → API Key
VOLCENGINE_API_KEY=your-volcengine-speech-api-key
#
# 2) 主账号或子用户 IAM → 访问密钥（用于 TOS 上传）
VOLCENGINE_ACCESS_KEY_ID=your-iam-access-key-id
VOLCENGINE_SECRET_ACCESS_KEY=your-iam-secret-access-key
#
# 3) TOS 对象存储 → 创建一个桶（bucket），名字填到这里
VOLCENGINE_TOS_BUCKET=your-tos-bucket-name
#
# 4) 桶所在区域，默认 cn-beijing；其他区域请改成对应代号（cn-shanghai / cn-guangzhou 等）
VOLCENGINE_TOS_REGION=cn-beijing

# ---------- 公开版字幕模式（一般用户不用动） ----------
# 设为 true 后只允许字幕路径，禁用音频识别。
PUBLIC_MODE=false
